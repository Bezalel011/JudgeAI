# =========================================
# Judgment-to-Action AI Environment Config
# =========================================

# -------------------
# Database
# -------------------
DATABASE_URL=sqlite:///./test.db

# -------------------
# OCR Configuration
# -------------------
# Path to Tesseract executable (Windows)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# OCR Language Models (space-separated, e.g., "eng+tam+hin")
# Default: English only
OCR_LANGUAGES=eng

# OCR Page Segmentation Mode (0-13)
# 3 = Fully automatic (default), 6 = Single uniform block of text
OCR_PSM=3

# Enable OCR fallback for text-based PDFs (True/False)
OCR_ENABLE_FALLBACK=True

# OCR timeout in seconds
OCR_TIMEOUT=30

# -------------------
# Document Storage
# -------------------
DOCUMENTS_DIR=data/documents

# -------------------
# API Configuration
# -------------------
MAX_UPLOAD_SIZE_MB=50
MAX_FILES_PER_UPLOAD=5

# -------------------
# Logging
# -------------------
LOG_LEVEL=INFO

# -------------------
# FastAPI
# -------------------
HOST=0.0.0.0
PORT=8000
DEBUG=True

# -------------------
# CORS
# -------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -------------------
# Scheduler / Alerts
# -------------------
ENABLE_SCHEDULER=True

# -------------------
# AI / NLP
# -------------------
SPACY_MODEL=en_core_web_sm